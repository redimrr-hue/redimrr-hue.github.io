let x = 0;
let size = 30;

function setup() {
  createCanvas(400, 400);
}

function draw() {
  background(220);

  x = x + 2;
  if (x > width) {
    x = 0;
  }

  let pulse = 30 + sin(frameCount * 0.1) * 15;

  let r = frameCount % 255;
  let g = 150;
  let b = 255 - r;

  fill(r, g, b);
  ellipse(x, height / 2, pulse, pulse);
}
